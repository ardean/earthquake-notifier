# Notification
NOTIFY_METHODS=discord
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
NOTIFY_STARTUP_SHUTDOWN=true

# Watch area (required) — example: Davao City, Davao del Sur
WATCH_LATITUDE=7.0662
WATCH_LONGITUDE=125.6094
WATCH_RADIUS_KM=400

# Event filters
MIN_MAGNITUDE=3.0
MAX_EVENT_AGE=7d
CHECK_INTERVAL=2m
LOOKBACK=24h

# Persistence (use data/ locally; Docker sets STATE_FILE=/data/seen_events.json)
STATE_FILE=data/seen_events.json
